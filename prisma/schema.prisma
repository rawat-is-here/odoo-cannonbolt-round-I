generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum EmissionScope {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}

enum CarbonRecordStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum FactorStatus {
  ACTIVE
  INACTIVE
}

enum DataQuality {
  PRIMARY
  SECONDARY
  ESTIMATED
}

model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?
  role          String  @default("USER")

  organizationId String?
  departmentId   String?

  employeeCode String?
  designation  String?
  status       UserStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  sessions Session[]
  accounts Account[]

  submittedCarbonRecords CarbonRecord[] @relation("SubmittedCarbonRecords")
  approvedCarbonRecords  CarbonRecord[] @relation("ApprovedCarbonRecords")

  @@index([organizationId])
  @@index([departmentId])
  @@index([status])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id         String @id
  accountId  String
  providerId String
  userId     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id String @id @default(cuid())

  name      String
  legalName String?
  slug      String  @unique
  gstin     String? @unique
  joinCode  String? @unique

  industry    String?
  country     String  @default("India")
  companySize String?

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments Department[]
  employees   User[]

  emissionFactors EmissionFactor[]
  carbonRecords   CarbonRecord[]

  @@index([name])
  @@map("organization")
}

model Department {
  id String @id @default(cuid())

  organizationId String

  name String
  code String

  description   String?
  employeeCount Int     @default(0)
  status        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employees     User[]
  carbonRecords CarbonRecord[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
  @@map("department")
}

model EmissionFactor {
  id String @id @default(cuid())

  organizationId String?

  activityCode String
  activityName String

  industryCode   String?
  departmentCode String?

  category    String
  subcategory String?

  scope EmissionScope

  inputUnit  String
  outputUnit String @default("kgCO2e")

  factorValue Decimal @db.Decimal(18, 8)

  country String?
  region  String?

  sourceName String
  sourceUrl  String?
  sourceYear Int?
  version    String?

  validFrom  DateTime?
  validUntil DateTime?

  description String?      @db.Text
  status      FactorStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  carbonRecords CarbonRecord[]

  @@index([organizationId])
  @@index([activityCode])
  @@index([industryCode])
  @@index([departmentCode])
  @@index([scope])
  @@index([status])
  @@map("emission_factor")
}

model CarbonRecord {
  id String @id @default(cuid())

  organizationId String
  departmentId   String?

  submittedById String
  approvedById  String?

  emissionFactorId String

  activityCode String
  activityName String

  industryCode String?
  category     String
  subcategory  String?

  scope EmissionScope

  activityAmount Decimal @db.Decimal(18, 4)
  activityUnit   String

  factorValue Decimal @db.Decimal(18, 8)
  factorUnit  String

  co2eAmount Decimal @db.Decimal(18, 6)
  co2eUnit   String  @default("kgCO2e")

  calculationMethod  String  @default("ACTIVITY_X_FACTOR")
  calculationFormula String?

  dataQuality DataQuality @default(PRIMARY)

  notes        String? @db.Text
  activityData String? @db.Text
  evidenceUrl  String?

  status CarbonRecordStatus @default(SUBMITTED)

  occurredAt  DateTime
  submittedAt DateTime  @default(now())
  approvedAt  DateTime?

  prevHash String @default("")
  hash     String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  submittedBy User  @relation("SubmittedCarbonRecords", fields: [submittedById], references: [id], onDelete: Restrict)
  approvedBy  User? @relation("ApprovedCarbonRecords", fields: [approvedById], references: [id], onDelete: SetNull)

  emissionFactor EmissionFactor @relation(fields: [emissionFactorId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([departmentId])
  @@index([submittedById])
  @@index([approvedById])
  @@index([emissionFactorId])
  @@index([activityCode])
  @@index([scope])
  @@index([status])
  @@index([occurredAt])
  @@map("carbon_record")
}
